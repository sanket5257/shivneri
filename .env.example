# Resend — booking/consultation form email delivery
# 1. Create a key at https://resend.com/api-keys
# 2. Copy this file to .env.local and fill in the real values
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where consultation requests are delivered
BOOKING_TO_EMAIL=support@shivnerisystems.com

# Sender — must be on a domain verified in Resend.
# For quick testing you can use: Shivneri Website <onboarding@resend.dev>
# (onboarding@resend.dev only delivers to the Resend account owner's email)
BOOKING_FROM_EMAIL=Shivneri Website <bookings@shivnerisystems.com>
